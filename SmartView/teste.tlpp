#include "protheus.ch"
#include "msobject.ch"
#include "totvs.framework.treports.integratedprovider.th"

//-------------------------------------------------------------------
//*/{Protheus.doc} SB1TReportsBusinessObject
//Objeto de Negócio (SmartView) para visualizaçăo de Produtos (SB1).
