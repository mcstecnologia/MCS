#include "protheus.ch"
#INCLUDE "FWMBROWSE.CH"
#INCLUDE "FWMVCDEF.CH"
#Include "FWEditPanel.CH"

//-------------------------------------------------------------------
/*/{Protheus.doc} FISA168()

Esta rotina tem objetivo de realizar cadastro dos tributos

Esta rotina estarß disponÝvel somente na versÒo 12.

@author joao.pellegrini
@since 11/09/2018
@version 12.1.17
/*/
//-------------------------------------------------------------------
User Function MCSFIS02()

    Local  oBrowse := Nil
    Local  xTabela1 := SuperGetMV("MX_XTABFIS",.F.,"WZA")
    Local  xTabela2 := SuperGetMV("MX_XTABFIS",.F.,"WZB")


    //Verifico se as tabelas existem antes de prosseguir
    IF AliasIndic(xTabela1) .And. AliasIndic(xTabela2)
        oBrowse := FWMBrowse():New()
        oBrowse:SetAlias(xTabela1)
        oBrowse:SetDescription("Cadastro de Cenßrio") // Cadastro de Tributos
        oBrowse:Activate()
    Else
        Help("",1,"Help","Help","Dicionßrio nÒo atualizado, verifique as tabelas envolvidas no processo ou rode UPD",1,0) // Dicionßrio desatualizado, verifique as atualizaþ§es do motor tributßrio fiscal.
    EndIf

Return

/*/{Protheus.doc} MenuDef
CriaþÒo do menu
@type function
@version  
@author rodri
@since 3/27/2026
@return variant, return_description
/*/
Static Function MenuDef()

    Local aRot := {}
     
    //Adicionando opþ§es
    ADD OPTION aRot TITLE 'Visualizar' ACTION 'VIEWDEF.MCSFIS02' OPERATION MODEL_OPERATION_VIEW   ACCESS 0 //OPERATION 1
    //ADD OPTION aRot TITLE 'Legenda'    ACTION 'u_zMVC01Leg'     OPERATION 6                      ACCESS 0 //OPERATION X
    ADD OPTION aRot TITLE 'Incluir'    ACTION 'U_MCSINC01' OPERATION MODEL_OPERATION_INSERT ACCESS 0 //OPERATION 3
    ADD OPTION aRot TITLE 'Alterar'    ACTION 'VIEWDEF.MCSFIS02' OPERATION MODEL_OPERATION_UPDATE ACCESS 0 //OPERATION 4
    //ADD OPTION aRot TITLE 'Excluir'    ACTION 'VIEWDEF.MCSFIS02' OPERATION MODEL_OPERATION_DELETE ACCESS 0 //OPERATION 5
 
Return aRot
 
/*/{Protheus.doc} ModelDef
Criaþao do modelo
@type function
@version  
@author rodri
@since 3/27/2026
@return variant, return_description
/*/
Static Function ModelDef()

    Local  xTabela1 := SuperGetMV("MX_XTABFIS",.F.,"WZA")
    Local oModel := Nil
     
    Local oStruct := FWFormStruct(1, xTabela1)
     
    oModel := MPFormModel():New("MCSFIS02A",/*bPre*/, /*bPos*/,/*bCommit*/,/*bCancel*/) 
     
    oModel:AddFields("MCSFIS02",/*cOwner*/,oStruct)
     
    oModel:SetPrimaryKey({xTabela1+'_FILIAL',''+xTabela1+'_ID'})
     
    oModel:SetDescription("Cadastro de Cenßrio")
     
    oModel:GetModel("MCSFIS02"):SetDescription("Cenßrio")

Return oModel
 
/*/{Protheus.doc} ViewDef
criaþÒo da visÒo
@type function
@version  
@author rodri
@since 3/27/2026
@return variant, return_description
/*/
Static Function ViewDef()

    Local oModel := FWLoadModel("MCSFIS02")
    Local  xTabela1 := SuperGetMV("MX_XTABFIS",.F.,"WZA")
     
    //CriaþÒo da estrutura de dados utilizada na interface do cadastro de Autor
    Local oStruct := FWFormStruct(2, xTabela1)  //pode se usar um terceiro parÔmetro para filtrar os campos exibidos { |cCampo| cCampo $ 'SBM_NOME|SBM_DTAFAL|'}
     
    Local oView := Nil

    oView := FWFormView():New()
    oView:SetModel(oModel)
     
    oView:AddField("VIEW_"+xTabela1, oStruct, "MCSFIS02")
     
    oView:CreateHorizontalBox("TELA",100)
     
    oView:EnableTitleView('VIEW_'+xTabela1, 'Cenßrios gerados' )  
     
    oView:SetCloseOnOk({||.T.})
     
    oView:SetOwnerView("VIEW_"+xTabela1,"TELA")

Return oView
 

/*/{Protheus.doc} zMVC01Leg
Legenda
@type function
@version  
@author rodri
@since 3/27/2026
@return variant, return_description
/*/ 
User Function zMVC01Leg()
    Local aLegenda := {}
     
    //Monta as cores
    AADD(aLegenda,{"BR_VERDE",        "Original"  })
    AADD(aLegenda,{"BR_VERMELHO",    "NÒo Original"})
     
    BrwLegenda("Grupo de Produtos", "Procedencia", aLegenda)
Return

/*/{Protheus.doc} MCSINC01
InclusÒo da regra 
@type function
@version  
@author rodri
@since 3/27/2026
@return variant, return_description
/*/
User Function MCSINC01()


    Local oGet1
    Local cGet1 := ""
    Local oGet2
    Local cGet2 := ""
    Local oGroup1
    Local oSay1
    Local oSay2
    Local oSay3
    Static oDlg

    DEFINE MSDIALOG oDlg TITLE "ConfiguraþÒo de Cenßrio" FROM 000, 000  TO 800, 1200 COLORS 0, 16777215 PIXEL

        @ 008, 006 GROUP oGroup1 TO 394, 591 PROMPT "CriaþÒo de Cenßrio" OF oDlg COLOR 0, 16777215 PIXEL
        @ 025, 105 SAY oSay1 PROMPT "DescriþÒo" SIZE 025, 007 OF oDlg COLORS 0, 16777215 PIXEL
        @ 024, 139 MSGET oGet1 VAR cGet1 SIZE 424, 010 OF oDlg COLORS 0, 16777215 PIXEL
        @ 025, 019 SAY oSay2 PROMPT "C¾digo:" SIZE 025, 007 OF oDlg COLORS 0, 16777215 PIXEL
        @ 024, 040 MSGET oGet2 VAR cGet2 SIZE 060, 010 OF oDlg COLORS 0, 16777215 PIXEL
        @ 061, 020 SAY oSay3 PROMPT "Tributos" SIZE 025, 007 OF oDlg COLORS 0, 16777215 PIXEL

    ACTIVATE MSDIALOG oDlg CENTERED

Return
